<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Prevent automatic generation of assembly attributes to avoid duplicate attribute errors -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Prevent automatic generation of TargetFrameworkAttribute to avoid duplicate attribute errors from generated files -->
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.105.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.8" />
    <PackageReference Include="Microsoft.OpenApi.Readers" Version="1.6.29" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="ApiTestAssistant.Tests\" />
    <Folder Include="Properties\" />
  </ItemGroup>

</Project>
